# Rust build output
/target/
/fuzz/target/
/fuzz/artifacts/
/fuzz/coverage/
/fuzz/corpus/
/saw/extracted/target/
/saw/extracted/proof-target/
/saw/extracted/*.bc
/saw/extracted/*.d
/saw/extracted/*.so

# Python bytecode and test caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Local editor and OS files
*.swp
*.swo
*~
.DS_Store

# Local environment and logs
.env
.env.*
!.env.example
*.log

# Local E2E / ceremony scratch artifacts when created in the repo root
/converted.txt
/legacy.txt
/legacy_shares.txt
/imported_wrap_id.txt
/raw_setup.log
/wrapped_victim.bin
/victim_pubkey.pem
/victim_pubkey.after.pem
/keymat-*/
/out/
/tmp/
/FIX_PLAN.html

# Coverage/profiling artifacts
*.profraw
*.profdata
/coverage/

# R11-V2-residue / SD-7: dhat heap-profile output. The
# `recover_makes_at_most_one_heap_alloc` test writes this in testing
# mode and on assert-failure; it must not be committed.
dhat-heap.json

# R11-C3 D4: editor / IDE / agent scratch & backup detritus.
# These directories and patterns are common across IDEs, OSes, and
# Claude-style agents; committing any of them by accident would leak
# local config or in-flight scratch into the repo.
.vscode/
.idea/
*.bak
*.orig
.claude/
.codex/
.agents/
ceremony/
scratch/
