# R13-F / item 6: single source of truth for the pinned Docker image
# digests consumed by BOTH the CI workflows (cryptol-proofs.yml +
# saw-proofs.yml) AND the local-run wrapper (scripts/run-proofs.sh).
# Rotation is manual: a single PR updates both lines + the matching
# CI image refs when a new Cryptol/SAW release ships.
# Dependabot's docker ecosystem does NOT scan .env files; rotation
# discipline is by-eyeball during the quarterly toolchain rotation
# (see saw/MAINTENANCE.md). [L-r3-1 v2-residue fix]
CRYPTOL_IMAGE=ghcr.io/galoisinc/cryptol@sha256:c9d1747394773edf5c36fd9544498c454bee737b8ea99cee469c6dde81d7f227
SAW_IMAGE=ghcr.io/galoisinc/saw@sha256:c771f4949415ec0f2c3c4ea54b864a44c9ab7a2b0d822d96998574293552f32f
